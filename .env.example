# ==========================================
# Application Configuration
# ==========================================

# Environment mode: development, staging, production
APP_ENV=development

# Host to bind the server
APP_HOST=0.0.0.0

# Port for the API server
APP_PORT=8000

# ==========================================
# Database Configuration
# ==========================================

# SQLAlchemy URL for SQLite or Postgres
DATABASE_URL=sqlite+aiosqlite:///reporag.db

# ==========================================
# Neo4j Graph Database
# ==========================================

# Connection URI
NEO4J_URI=bolt://localhost:7687

# Username (default is usually neo4j)
NEO4J_USERNAME=neo4j

# Password for Neo4j
NEO4J_PASSWORD=password

# ==========================================
# Qdrant Vector Store
# ==========================================

# Qdrant URL
QDRANT_URL=http://localhost:6333

# API Key (leave empty for local docker instances)
QDRANT_API_KEY=

# ==========================================
# LLM Provider Configuration
# ==========================================

# Provider: openai or anthropic
LLM_PROVIDER=openai

# API Key for OpenAI
OPENAI_API_KEY=

# API Key for Anthropic
ANTHROPIC_API_KEY=

# ==========================================
# Authentication & Security
# ==========================================

# Secret key for encrypting sessions and data
SECRET_KEY=super-secret-key

# Secret key for signing JWT tokens
JWT_SECRET_KEY=super-jwt-key

# Google OAuth2 Client Secret
GOOGLE_CLIENT_SECRET=
